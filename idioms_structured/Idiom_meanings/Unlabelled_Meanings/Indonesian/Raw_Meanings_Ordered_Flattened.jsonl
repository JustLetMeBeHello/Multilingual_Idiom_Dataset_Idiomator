["id_unspecified_0000", [{"idiom_id": "id_unspecified_0000", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["A literal question meaning 'is there anything?' or 'is something the matter?' used to ask whether something exists or is wrong."], "version": 1, "created_at": "2025-11-15 05:25:26.393698", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ada apa", "meaning_id\r": "366b823f-0e69-4bb5-a619-9bb07fd74e45\r"}, {"idiom_id": "id_unspecified_0000", "sense_number": 2, "register": ["informal", "colloquial", "idiomatic"], "region": ["Indonesia"], "definitions": ["An expression of concern or request for explanation meaning 'what's going on?' or 'what's the matter?' used to prompt someone to explain a situation or their feelings."], "version": 1, "created_at": "2025-11-15 05:25:26.393729", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ada apa", "meaning_id\r": "a31e9067-6814-433d-b9d4-8b618236ab4c\r"}]]
["id_unspecified_0001", [{"idiom_id": "id_unspecified_0001", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia", "Malay"], "definitions": ["A literal phrase meaning 'there is a shrimp behind the rock.'"], "version": 1, "created_at": "2025-11-15 05:25:26.393743", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ada udang di balik batu", "meaning_id\r": "13ef1270-fd4f-483f-a412-091bd46a76ff\r"}, {"idiom_id": "id_unspecified_0001", "sense_number": 2, "register": ["idiomatic", "colloquial", "figurative"], "region": ["Indonesia", "Malay"], "definitions": ["An idiom meaning there is a concealed ulterior motive or hidden catch behind an action, offer, or statement."], "version": 1, "created_at": "2025-11-15 05:25:26.393755", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ada udang di balik batu", "meaning_id\r": "dfc3839e-311d-40cd-8546-a25929765267\r"}]]
["id_unspecified_0002", [{"idiom_id": "id_unspecified_0002", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["A literal proverb meaning 'calm (or still) water carries away,' describing the behavior of water that appears calm on the surface."], "version": 1, "created_at": "2025-11-15 05:25:26.393767", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "air tenang menghanyutkan", "meaning_id\r": "1bf60167-3e73-4d7d-918d-37101d0ea079\r"}, {"idiom_id": "id_unspecified_0002", "sense_number": 2, "register": ["idiomatic", "proverbial", "figurative"], "region": ["Indonesia"], "definitions": ["A proverb meaning 'still waters run deep,' used to describe a quiet or reserved person who nonetheless has hidden depth, capability, or potential influence."], "version": 1, "created_at": "2025-11-15 05:25:26.393777", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "air tenang menghanyutkan", "meaning_id\r": "1f69eb69-d828-4b05-b1a1-868607f2201a\r"}]]
["id_unspecified_0003", [{"idiom_id": "id_unspecified_0003", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["To sleep together or share a bed with someone; a literal description of occupying the same bed for rest or sleep."], "version": 1, "created_at": "2025-11-15 05:25:26.393786", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "berseketiduran", "meaning_id\r": "aad3e759-c4e8-43fe-8ad6-b497e5bd934e\r"}, {"idiom_id": "id_unspecified_0003", "sense_number": 2, "register": ["euphemistic", "informal", "idiomatic", "figurative"], "region": ["Indonesia"], "definitions": ["A euphemistic idiom meaning to have sexual intercourse with someone."], "version": 1, "created_at": "2025-11-15 05:25:26.393796", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "berseketiduran", "meaning_id\r": "f120f9d3-5d89-4e09-a7ca-60a11827cf9b\r"}]]
["id_unspecified_0004", [{"idiom_id": "id_unspecified_0004", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["A literal phrase meaning 'the peg (stake) is larger than the post,' picturing an imbalance between components of a structure."], "version": 1, "created_at": "2025-11-15 05:25:26.393805", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "besar pasak daripada tiang", "meaning_id\r": "fd6cfa56-8ff2-449a-8c38-495684e73f34\r\n"}, {"idiom_id": "id_unspecified_0004", "sense_number": 2, "register": ["idiomatic", "proverbial", "figurative"], "region": ["Indonesia"], "definitions": ["An idiom meaning one's expenditures exceed one's income; spending more than one can afford."], "version": 1, "created_at": "2025-11-15 05:25:26.393814", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "besar pasak daripada tiang", "meaning_id\r": "c5256a7a-14cf-4037-85ea-d71c30492c28\r"}]]
["id_unspecified_0005", [{"idiom_id": "id_unspecified_0005", "sense_number": 1, "register": ["informal", "colloquial"], "region": ["Indonesia", "Jakarta"], "definitions": ["To leave something as it is; not to touch, change, or interfere with it."], "version": 1, "created_at": "2025-11-15 05:25:26.393823", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "biarin", "meaning_id\r": "2174e7fc-7c5d-4e2a-b19c-401185b96dc6\r"}, {"idiom_id": "id_unspecified_0005", "sense_number": 2, "register": ["informal", "colloquial", "slang"], "region": ["Indonesia", "Jakarta"], "definitions": ["Used as an imperative or response meaning 'let it be', 'never mind', 'don't worry about it', or 'leave him/her/them alone'."], "version": 1, "created_at": "2025-11-15 05:25:26.393832", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "biarin", "meaning_id\r": "32c6f2ed-f61a-48b9-a792-e3a47e1aee97\r"}]]
["id_unspecified_0006", [{"idiom_id": "id_unspecified_0006", "sense_number": 1, "register": ["informal", "slang"], "region": ["Indonesia"], "definitions": ["Literally 'very stupid' (from 'bodoh amat')."], "version": 1, "created_at": "2025-11-15 05:25:26.393841", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "bodo amat", "meaning_id\r": "5e5b9ac1-4af9-4c3f-b28c-3ff9c9ca054d\r"}, {"idiom_id": "id_unspecified_0006", "sense_number": 2, "register": ["informal", "slang"], "region": ["Indonesia"], "definitions": ["Expresses indifference or apathy; 'I don't care' or 'whatever'."], "version": 1, "created_at": "2025-11-15 05:25:26.39385", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "bodo amat", "meaning_id\r": "4728c435-bb5e-4f32-b34d-553931c91ddb\r"}]]
["id_unspecified_0007", [{"idiom_id": "id_unspecified_0007", "sense_number": 1, "register": ["informal", "slang", "nonstandard"], "region": ["Indonesia"], "definitions": ["Colloquial clipped form of 'bodo amat' used to express indifference; 'I don't care'."], "version": 1, "created_at": "2025-11-15 05:25:26.393859", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "bomat", "meaning_id\r": "1c36bcaf-c7da-414b-87de-0635f0cb8383\r"}]]
["id_unspecified_0008", [{"idiom_id": "id_unspecified_0008", "sense_number": 1, "register": ["neutral", "idiomatic"], "region": ["Indonesia"], "definitions": ["Literally 'one-night love'; a romantic or sexual encounter that lasts only one night."], "version": 1, "created_at": "2025-11-15 05:25:26.393868", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "cinta satu malam", "meaning_id\r": "2b980c33-8572-4667-8f6b-c3ffbedc4d53\r"}, {"idiom_id": "id_unspecified_0008", "sense_number": 2, "register": ["informal", "idiomatic"], "region": ["Indonesia"], "definitions": ["A casual sexual relationship with no expectation of commitment or continuation; a one-night stand."], "version": 1, "created_at": "2025-11-15 05:25:26.393877", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "cinta satu malam", "meaning_id\r": "1404ec56-e0db-433d-844c-380402bbbd4d\r"}]]
["id_unspecified_0009", [{"idiom_id": "id_unspecified_0009", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia", "Malay-speaking areas"], "definitions": ["Literally 'a durian falling'\u2014an occurrence of durian fruit falling from a tree."], "version": 1, "created_at": "2025-11-15 05:25:26.393891", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "durian runtuh", "meaning_id\r": "8e68faf1-a406-4757-b00f-209800bdb4b6\r"}, {"idiom_id": "id_unspecified_0009", "sense_number": 2, "register": ["idiomatic", "informal"], "region": ["Indonesia", "Malay-speaking areas"], "definitions": ["An unexpected windfall or stroke of good fortune; a sudden profitable gain."], "version": 1, "created_at": "2025-11-15 05:25:26.393911", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "durian runtuh", "meaning_id\r": "cb0b6cd2-28d3-49ae-8182-8cecb6b043dc\r"}]]
["id_unspecified_0010", [{"idiom_id": "id_unspecified_0010", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia"], "definitions": ["Literal: to dig a hole and then fill or close it, referring to the physical action of making and covering an excavation."], "version": 1, "created_at": "2025-11-15 05:25:26.393922", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "gali lubang, tutup lubang", "meaning_id\r": "6ed7aec8-cfeb-4df2-9cf4-228e4f4e51ec\r"}, {"idiom_id": "id_unspecified_0010", "sense_number": 2, "register": ["informal", "colloquial"], "region": ["Indonesia"], "definitions": ["Figurative: to borrow or take on new obligations in order to pay off existing ones, creating a cycle of debt or temporary fixes that conceal underlying problems."], "version": 1, "created_at": "2025-11-15 05:25:26.393934", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "gali lubang, tutup lubang", "meaning_id\r": "fb71530a-f157-4727-8487-bb1352ea1e33\r"}]]
["id_unspecified_0011", [{"idiom_id": "id_unspecified_0011", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia"], "definitions": ["Literal: to become a person or to attain the status of being a human individual."], "version": 1, "created_at": "2025-11-15 05:25:26.393943", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "jadi orang", "meaning_id\r": "65ccdd4f-87c2-48fc-a2a8-60bd2b261925\r"}, {"idiom_id": "id_unspecified_0011", "sense_number": 2, "register": ["informal", "colloquial"], "region": ["Indonesia"], "definitions": ["Figurative (maturational): to grow up, mature, or behave responsibly as an adult."], "version": 1, "created_at": "2025-11-15 05:25:26.393952", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "jadi orang", "meaning_id\r": "b083f51e-f40d-4278-a092-f62001b1fabf\r"}, {"idiom_id": "id_unspecified_0011", "sense_number": 3, "register": ["informal", "colloquial"], "region": ["Indonesia"], "definitions": ["Figurative (social success): to become successful, prominent, or respected; to 'be somebody' in terms of social status or achievement."], "version": 1, "created_at": "2025-11-15 05:25:26.39396", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "jadi orang", "meaning_id\r": "ad50bdeb-3e33-4fd2-83dc-3e972db01bc1\r"}]]
["id_unspecified_0012", [{"idiom_id": "id_unspecified_0012", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia"], "definitions": ["Literal: plural of kaleng; cans or tins used to hold food or other substances."], "version": 1, "created_at": "2025-11-15 05:25:26.393992", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kaleng-kaleng", "meaning_id\r": "6ff6d58d-b3f0-476e-9857-0abf9f79150a\r"}, {"idiom_id": "id_unspecified_0012", "sense_number": 2, "register": ["informal", "colloquial", "pejorative"], "region": ["Indonesia"], "definitions": ["Figurative: not genuine or of poor quality; makeshift, flimsy, or a sham rather than a real or proper item or arrangement."], "version": 1, "created_at": "2025-11-15 05:25:26.394002", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kaleng-kaleng", "meaning_id\r": "ba1d8109-0af4-4a9b-a104-b4817eb8fd94\r"}]]
["id_unspecified_0013", [{"idiom_id": "id_unspecified_0013", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia"], "definitions": ["Literal: a black goat, referring to an animal of that color."], "version": 1, "created_at": "2025-11-15 05:25:26.39402", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kambing hitam", "meaning_id\r": "84810250-32c1-4dba-bad8-7ebbf332db37\r"}, {"idiom_id": "id_unspecified_0013", "sense_number": 2, "register": ["neutral", "idiomatic"], "region": ["Indonesia"], "definitions": ["Figurative: a person or group unfairly blamed for the faults, mistakes, or problems of others; a scapegoat."], "version": 1, "created_at": "2025-11-15 05:25:26.39403", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kambing hitam", "meaning_id\r": "dd9afb98-de7d-4374-9c5f-6a8f9c48bc7d\r"}]]
["id_unspecified_0014", [{"idiom_id": "id_unspecified_0014", "sense_number": 1, "register": ["neutral", "formal"], "region": ["Indonesia"], "definitions": ["Literal: special requirements or specific needs that differ from the usual or standard."], "version": 1, "created_at": "2025-11-15 05:25:26.394039", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kebutuhan khusus", "meaning_id\r": "9ae9913a-d173-46b4-98b5-67404ec791b0\r"}, {"idiom_id": "id_unspecified_0014", "sense_number": 2, "register": ["neutral", "formal"], "region": ["Indonesia"], "definitions": ["Idiomatic: specific needs for additional care, services, or accommodations due to disabilities, developmental differences, or other conditions that require specialized support."], "version": 1, "created_at": "2025-11-15 05:25:26.394047", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kebutuhan khusus", "meaning_id\r": "a4e152b5-4c3d-4a45-bd4d-63abcca2aa74\r"}]]
["id_unspecified_0015", [{"idiom_id": "id_unspecified_0015", "sense_number": 1, "register": ["literal", "informal"], "region": ["Indonesia"], "definitions": ["Literally \"cowboy worm\": a compound of 'koboi' (cowboy) and 'cacing' (worm), a literal phrase with no common neutral usage."], "version": 1, "created_at": "2025-11-15 05:25:26.394057", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "koboi cacing", "meaning_id\r": "67158b7e-ede5-49ee-b17a-46930fa198f6\r"}, {"idiom_id": "id_unspecified_0015", "sense_number": 2, "register": ["informal", "derogatory", "idiomatic", "slang"], "region": ["Indonesia"], "definitions": ["A person who pretends to be tough or brave but is actually weak and easily frightened."], "version": 1, "created_at": "2025-11-15 05:25:26.394066", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "koboi cacing", "meaning_id\r": "064df3fb-576e-4f51-8130-4feb5b94b125\r"}]]
["id_unspecified_0016", [{"idiom_id": "id_unspecified_0016", "sense_number": 1, "register": ["literal", "informal"], "region": ["Indonesia"], "definitions": ["Literally \"cowboy crybaby\": a compound of 'koboi' (cowboy) and 'cengeng' (crying or whiny person), a literal combination used mainly for effect."], "version": 1, "created_at": "2025-11-15 05:25:26.394091", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "koboi cengeng", "meaning_id\r": "eb14c34c-2fc6-4afc-9526-4cc92fb4c447\r"}, {"idiom_id": "id_unspecified_0016", "sense_number": 2, "register": ["informal", "derogatory", "idiomatic", "slang"], "region": ["Indonesia"], "definitions": ["A person who acts tough or boastful but is actually timid, whiny, or easily upset."], "version": 1, "created_at": "2025-11-15 05:25:26.394123", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "koboi cengeng", "meaning_id\r": "7182558d-eaea-449c-840b-cb7c40f8e7c5\r"}]]
["id_unspecified_0017", [{"idiom_id": "id_unspecified_0017", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia"], "definitions": ["Literally 'lacking work': having insufficient work or not enough tasks to occupy oneself."], "version": 1, "created_at": "2025-11-15 05:25:26.394132", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kurang kerjaan", "meaning_id\r": "05574234-dfab-4c21-9b32-9040df605a83\r"}, {"idiom_id": "id_unspecified_0017", "sense_number": 2, "register": ["informal", "colloquial", "idiomatic"], "region": ["Indonesia"], "definitions": ["Used derogatorily to say someone has nothing better to do, implying they waste time on trivial, bothersome, or unnecessary activities."], "version": 1, "created_at": "2025-11-15 05:25:26.394141", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "kurang kerjaan", "meaning_id\r": "58f52d99-a032-4dce-ab57-c568346aa209\r"}]]
["id_unspecified_0018", [{"idiom_id": "id_unspecified_0018", "sense_number": 1, "register": ["neutral", "colloquial"], "region": ["Indonesia", "Malaysia", "Singapore"], "definitions": ["To eat; to consume food."], "version": 1, "created_at": "2025-11-15 05:25:26.394153", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "makan", "meaning_id\r": "94d01d90-983d-470a-8d01-e26c2165c9ce\r"}]]
["id_unspecified_0019", [{"idiom_id": "id_unspecified_0019", "sense_number": 1, "register": ["literal"], "region": ["Indonesia", "Malaysia"], "definitions": ["Literally 'to eat wind': to take in or consume wind or air (literal meaning, rarely used)."], "version": 1, "created_at": "2025-11-15 05:25:26.394162", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "makan angin", "meaning_id\r": "28813424-076b-4c18-bca4-2a70ac6891d2\r"}, {"idiom_id": "id_unspecified_0019", "sense_number": 2, "register": ["informal", "idiomatic", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To go out for a leisurely walk or outing to enjoy fresh air and relaxation."], "version": 1, "created_at": "2025-11-15 05:25:26.394178", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "makan angin", "meaning_id\r": "619aa73b-927b-4fc4-a965-7dcd3851f412\r"}, {"idiom_id": "id_unspecified_0019", "sense_number": 3, "register": ["informal", "idiomatic", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To idle or loiter; to pass time aimlessly by sitting around or wandering without purpose."], "version": 1, "created_at": "2025-11-15 05:25:26.394189", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "makan angin", "meaning_id\r": "baab14b7-4825-4262-9eb2-9805bae2cffa\r"}]]
["id_unspecified_0020", [{"idiom_id": "id_unspecified_0020", "sense_number": 1, "register": ["informal", "slang"], "region": ["Indonesia"], "definitions": ["Literally, 'time ignorant'; a literal composition of the words but not commonly used on its own to convey a concrete event or object."], "version": 1, "created_at": "2025-11-15 05:25:26.394199", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "masa bodo", "meaning_id\r": "6717a494-ca51-4721-837d-1d42fa210d87\r"}, {"idiom_id": "id_unspecified_0020", "sense_number": 2, "register": ["informal", "slang", "idiomatic"], "region": ["Indonesia"], "definitions": ["Figuratively, an expression of indifference or lack of concern; equivalent to 'I don't care' or 'whatever'."], "version": 1, "created_at": "2025-11-15 05:25:26.394208", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "masa bodo", "meaning_id\r": "f625978d-69e7-45d0-bae8-c34e1dc745af\r"}]]
["id_unspecified_0021", [{"idiom_id": "id_unspecified_0021", "sense_number": 1, "register": ["informal", "idiomatic"], "region": ["Indonesia"], "definitions": ["Literally, 'time of being ignorant' or 'a period of not knowing'; a direct compositional reading of the words rather than a common literal referent."], "version": 1, "created_at": "2025-11-15 05:25:26.394222", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "masa bodoh", "meaning_id\r": "3dbb8f9d-cec2-49bd-93ba-2ee205753f3b\r"}, {"idiom_id": "id_unspecified_0021", "sense_number": 2, "register": ["informal", "idiomatic"], "region": ["Indonesia"], "definitions": ["Figuratively, careless, indifferent, or apathetic; used to indicate that one does not care about someone or something."], "version": 1, "created_at": "2025-11-15 05:25:26.394232", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "masa bodoh", "meaning_id\r": "bad57354-d083-45a6-a0a0-9fa6ac2f6c4c\r"}]]
["id_unspecified_0022", [{"idiom_id": "id_unspecified_0022", "sense_number": 1, "register": ["idiomatic", "proverbial"], "region": ["Indonesia"], "definitions": ["Literally, 'three go in, four come out'; a compositional image describing a mismatch between input and output."], "version": 1, "created_at": "2025-11-15 05:25:26.394242", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "masuk tiga, keluar empat", "meaning_id\r": "60f7a391-d4f8-490b-956a-585011488330\r"}, {"idiom_id": "id_unspecified_0022", "sense_number": 2, "register": ["idiomatic", "proverbial"], "region": ["Indonesia"], "definitions": ["Figuratively, to spend more than one earns or to have expenses exceed income; to be in deficit (similar to 'besar pasak daripada tiang')."], "version": 1, "created_at": "2025-11-15 05:25:26.394251", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "masuk tiga, keluar empat", "meaning_id\r": "92cc4243-e2b5-47bf-baaf-aa0431737027\r"}]]
["id_unspecified_0023", [{"idiom_id": "id_unspecified_0023", "sense_number": 1, "register": ["colloquial", "idiomatic", "proverbial"], "region": ["Indonesia"], "definitions": ["Literally, 'to receive an upturned/overturned banana'; a concrete image referring to an easily obtained object."], "version": 1, "created_at": "2025-11-15 05:25:26.394259", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "mendapat pisang terkubak", "meaning_id\r": "579ef410-5ed2-4e00-aa01-69897989358b\r"}, {"idiom_id": "id_unspecified_0023", "sense_number": 2, "register": ["colloquial", "idiomatic", "proverbial"], "region": ["Indonesia"], "definitions": ["Figuratively, to gain a profit, benefit, or windfall effortlessly or without hard work; to receive an unexpected or easy reward."], "version": 1, "created_at": "2025-11-15 05:25:26.394269", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "mendapat pisang terkubak", "meaning_id\r": "c02c3479-176a-4ca0-9c5e-f833f05dbdd4\r"}]]
["id_unspecified_0024", [{"idiom_id": "id_unspecified_0024", "sense_number": 1, "register": ["colloquial", "internet slang"], "region": ["Indonesia"], "definitions": ["Literally, 'according to you'; a direct phrasing asking for or attributing an opinion to the addressee."], "version": 1, "created_at": "2025-11-15 05:25:26.394282", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "menurut ngana", "meaning_id\r": "1fded887-9ae8-4bd2-8fa6-5604b6d0cddc\r"}, {"idiom_id": "id_unspecified_0024", "sense_number": 2, "register": ["colloquial", "internet slang", "idiomatic"], "region": ["Indonesia"], "definitions": ["Figuratively, a sarcastic or rhetorical response to an obvious statement meaning 'you think?' or 'you don't say?', used to express surprise-mocking or to highlight the obviousness of something."], "version": 1, "created_at": "2025-11-15 05:25:26.394675", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "menurut ngana", "meaning_id\r": "248fc8c0-b4d0-47b9-8fbb-ecea434c15db\r"}]]
["id_unspecified_0025", [{"idiom_id": "id_unspecified_0025", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["An enemy physically concealed under bedding or inside a blanket."], "version": 1, "created_at": "2025-11-15 05:25:26.394691", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "musuh dalam selimut", "meaning_id\r": "cee5d1e7-4615-482d-a934-40056afa0728\r"}, {"idiom_id": "id_unspecified_0025", "sense_number": 2, "register": ["idiomatic", "colloquial"], "region": ["Indonesia"], "definitions": ["A hidden or internal enemy; a person within a group who secretly betrays or works against that group."], "version": 1, "created_at": "2025-11-15 05:25:26.3947", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "musuh dalam selimut", "meaning_id\r": "cc04d1d8-36fe-4261-b6d0-76074a5b4ecc\r"}]]
["id_unspecified_0026", [{"idiom_id": "id_unspecified_0026", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["Rice that has been cooked until it has become porridge."], "version": 1, "created_at": "2025-11-15 05:25:26.394708", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "nasi sudah menjadi bubur", "meaning_id\r": "57dfde12-0cf4-48f7-abb2-fc269d25860c\r"}, {"idiom_id": "id_unspecified_0026", "sense_number": 2, "register": ["idiomatic", "colloquial"], "region": ["Indonesia"], "definitions": ["What is done is done; an irreversible situation that cannot be changed."], "version": 1, "created_at": "2025-11-15 05:25:26.394716", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "nasi sudah menjadi bubur", "meaning_id\r": "ac1a3e6e-9838-4cb4-b881-5cbc3bf01a8b\r"}]]
["id_unspecified_0027", [{"idiom_id": "id_unspecified_0027", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["A substance, such as a spray or coil, used to repel or kill mosquitoes and other insects."], "version": 1, "created_at": "2025-11-15 05:25:26.394723", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "obat nyamuk", "meaning_id\r": "488be34a-808a-477b-b501-f67df7aea6d1\r"}, {"idiom_id": "id_unspecified_0027", "sense_number": 2, "register": ["idiomatic", "colloquial"], "region": ["Indonesia"], "definitions": ["A third, unwanted person accompanying a pair (a 'third wheel') who disrupts or intrudes on a couple's interaction."], "version": 1, "created_at": "2025-11-15 05:25:26.394739", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "obat nyamuk", "meaning_id\r": "8d9a74d4-4499-4052-9445-c284f92a10d5\r"}]]
["id_unspecified_0028", [{"idiom_id": "id_unspecified_0028", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["Having physically long arms or an extended reach."], "version": 1, "created_at": "2025-11-15 05:25:26.394747", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "panjang tangan", "meaning_id\r": "887c9899-e381-4de7-9b4e-9ef8e346d7fd\r"}, {"idiom_id": "id_unspecified_0028", "sense_number": 2, "register": ["idiomatic", "colloquial"], "region": ["Indonesia"], "definitions": ["A person who steals or habitually takes things that do not belong to them; someone with 'sticky fingers.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394754", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "panjang tangan", "meaning_id\r": "4916cfa9-ddfd-47ae-8ce6-01daf68e6aea\r"}]]
["id_unspecified_0029", [{"idiom_id": "id_unspecified_0029", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia"], "definitions": ["The act or process of making something darker; darkening."], "version": 1, "created_at": "2025-11-15 05:25:26.394761", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "penggelapan", "meaning_id\r": "62660b6d-0652-4a1e-97e5-04c54b792d4f\r"}, {"idiom_id": "id_unspecified_0029", "sense_number": 2, "register": ["formal", "legal"], "region": ["Indonesia"], "definitions": ["The criminal or unlawful appropriation of funds or property entrusted to someone; embezzlement."], "version": 1, "created_at": "2025-11-15 05:25:26.394767", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "penggelapan", "meaning_id\r": "11f4bfd1-9a82-439b-bc2b-792d82e2f321\r"}]]
["id_unspecified_0030", [{"idiom_id": "id_unspecified_0030", "sense_number": 1, "register": ["proverbial", "literary"], "region": ["Malay", "Indonesian"], "definitions": ["literal translation: 'the favored shoot, and the dish arrives.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394773", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "pucuk dicinta, ulam pun tiba", "meaning_id\r": "87b79d10-bf73-4d4a-8b73-dc12e9ef9d07\r"}, {"idiom_id": "id_unspecified_0030", "sense_number": 2, "register": ["proverbial", "informal"], "region": ["Malay", "Indonesian"], "definitions": ["figurative: finally obtaining something that has been long desired; a wished-for thing or opportunity comes at last."], "version": 1, "created_at": "2025-11-15 05:25:26.39478", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "pucuk dicinta, ulam pun tiba", "meaning_id\r": "aedde722-2d4e-4f99-af9e-661b9a5df377\r"}]]
["id_unspecified_0031", [{"idiom_id": "id_unspecified_0031", "sense_number": 1, "register": ["colloquial", "affectionate"], "region": ["Malay", "Indonesian"], "definitions": ["literal translation: 'the heart's adored one.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394787", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "pujaan hati", "meaning_id\r": "4ae18715-aeaf-4495-877f-31660bb9e481\r"}, {"idiom_id": "id_unspecified_0031", "sense_number": 2, "register": ["colloquial", "affectionate"], "region": ["Malay", "Indonesian"], "definitions": ["figurative: a person one adores or cherishes; a beloved, darling, or romantic idol."], "version": 1, "created_at": "2025-11-15 05:25:26.394793", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "pujaan hati", "meaning_id\r": "47931ebd-ac9b-43be-a193-5d0fd9d05bac\r"}]]
["id_unspecified_0032", [{"idiom_id": "id_unspecified_0032", "sense_number": 1, "register": ["neutral"], "region": ["Indonesian"], "definitions": ["literal translation: 'banana republic.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394799", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "republik pisang", "meaning_id\r": "14a6c3a9-1d46-48be-9385-474b43e4f693\r"}, {"idiom_id": "id_unspecified_0032", "sense_number": 2, "register": ["derogatory", "informal"], "region": ["Indonesian"], "definitions": ["figurative: a derogatory term for a country perceived as politically unstable, corrupt, or governed by dictatorial elites and dependent on a single export commodity."], "version": 1, "created_at": "2025-11-15 05:25:26.394807", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "republik pisang", "meaning_id\r": "727f86e6-5914-48a8-bc6a-173f213f22a4\r"}]]
["id_unspecified_0033", [{"idiom_id": "id_unspecified_0033", "sense_number": 1, "register": ["neutral"], "region": ["Malay", "Indonesian"], "definitions": ["literal translation: 'light-handed' or 'light of hand.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394813", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ringan tangan", "meaning_id\r": "482d49b6-0ca0-4583-81a5-84a849b29002\r"}, {"idiom_id": "id_unspecified_0033", "sense_number": 2, "register": ["informal", "positive"], "region": ["Malay", "Indonesian"], "definitions": ["figurative: disposed to help others readily; quick to lend a hand."], "version": 1, "created_at": "2025-11-15 05:25:26.394819", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ringan tangan", "meaning_id\r": "91251b37-3859-4787-b676-ce04ed311e9b\r"}, {"idiom_id": "id_unspecified_0033", "sense_number": 3, "register": ["informal", "pejorative"], "region": ["Malay", "Indonesian"], "definitions": ["figurative: quick to strike or prone to hitting others; given to physical aggression."], "version": 1, "created_at": "2025-11-15 05:25:26.394826", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "ringan tangan", "meaning_id\r": "bf4107b6-6b6b-4a97-be99-2eda5b01549e\r"}]]
["id_unspecified_0034", [{"idiom_id": "id_unspecified_0034", "sense_number": 1, "register": ["neutral", "formal"], "region": ["Malay", "Indonesian"], "definitions": ["literal translation: 'entirely' or 'completely.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394832", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sama sekali", "meaning_id\r": "c30d879c-7aa3-444e-b8ce-c38391704f12\r"}, {"idiom_id": "id_unspecified_0034", "sense_number": 2, "register": ["neutral", "colloquial"], "region": ["Malay", "Indonesian"], "definitions": ["used as an intensifier in negative or restrictive contexts meaning 'at all' or 'in any way.'"], "version": 1, "created_at": "2025-11-15 05:25:26.394839", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sama sekali", "meaning_id\r": "945c8ef1-1c0d-4c94-9a7b-3d1901ea8e71\r"}]]
["id_unspecified_0035", [{"idiom_id": "id_unspecified_0035", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia", "Malaysia"], "definitions": ["Literally, 'to drink water while diving'; to perform the action of drinking while one is diving."], "version": 1, "created_at": "2025-11-15 05:25:26.394846", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sambil menyelam minum air", "meaning_id\r": "33f1a9b4-5460-43d3-a7c1-2716be5379d0\r"}, {"idiom_id": "id_unspecified_0035", "sense_number": 2, "register": ["colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To accomplish two aims in a single action; to obtain an additional benefit while carrying out another task."], "version": 1, "created_at": "2025-11-15 05:25:26.394856", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sambil menyelam minum air", "meaning_id\r": "ced78b4e-00e7-400b-a645-eac4478b37d5\r"}]]
["id_unspecified_0036", [{"idiom_id": "id_unspecified_0036", "sense_number": 1, "register": ["formal", "literary"], "region": ["Indonesia"], "definitions": ["Literally, 'until the blood is exhausted'; to continue until one's physical resources are spent."], "version": 1, "created_at": "2025-11-15 05:25:26.394865", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sampai titik darah penghabisan", "meaning_id\r": "b768bbdd-f769-451e-8762-e934200366bd\r"}, {"idiom_id": "id_unspecified_0036", "sense_number": 2, "register": ["formal", "emphatic"], "region": ["Indonesia"], "definitions": ["To struggle or fight to the utmost limit; to persist to the very last degree."], "version": 1, "created_at": "2025-11-15 05:25:26.394872", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sampai titik darah penghabisan", "meaning_id\r": "71e07fba-52d9-4f63-928e-0506d607e3ac\r"}]]
["id_unspecified_0037", [{"idiom_id": "id_unspecified_0037", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia"], "definitions": ["Literally, 'the valiant red one'; a personified expression referring to something red or splendid in hue."], "version": 1, "created_at": "2025-11-15 05:25:26.394896", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "si jago merah", "meaning_id\r": "29a90a8d-3964-4e80-9f24-50cf962c942a\r"}, {"idiom_id": "id_unspecified_0037", "sense_number": 2, "register": ["colloquial", "journalistic"], "region": ["Indonesia"], "definitions": ["A colloquial term for a destructive fire or blaze."], "version": 1, "created_at": "2025-11-15 05:25:26.394903", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "si jago merah", "meaning_id\r": "062b32b9-5a62-4532-aaa3-5fd1efec64f0\r"}]]
["id_unspecified_0038", [{"idiom_id": "id_unspecified_0038", "sense_number": 1, "register": ["colloquial"], "region": ["Indonesia"], "definitions": ["Literally, 'already fallen, then struck by a ladder'; an image of falling and then being hit by a ladder."], "version": 1, "created_at": "2025-11-15 05:25:26.394911", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sudah jatuh, tertimpa tangga", "meaning_id\r": "2dee01a4-5a59-4eee-b005-499176fe05b3\r"}, {"idiom_id": "id_unspecified_0038", "sense_number": 2, "register": ["colloquial"], "region": ["Indonesia"], "definitions": ["To suffer an additional misfortune on top of an existing one; to experience multiple setbacks in succession."], "version": 1, "created_at": "2025-11-15 05:25:26.394917", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "sudah jatuh, tertimpa tangga", "meaning_id\r": "5f982714-5d62-479a-b96d-fcf7541c836b\r"}]]
["id_unspecified_0039", [{"idiom_id": "id_unspecified_0039", "sense_number": 1, "register": ["neutral"], "region": ["Indonesia", "Malaysia"], "definitions": ["To know oneself; to understand one's own situation, abilities, or identity."], "version": 1, "created_at": "2025-11-15 05:25:26.394924", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tahu diri", "meaning_id\r": "f3b2a3c1-dc49-4319-b9b5-04e6377ddd8f\r"}, {"idiom_id": "id_unspecified_0039", "sense_number": 2, "register": ["informal", "disparaging"], "region": ["Indonesia", "Malaysia"], "definitions": ["To know one's place; to behave with appropriate modesty or restraint and avoid presumptuous conduct."], "version": 1, "created_at": "2025-11-15 05:25:26.394931", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tahu diri", "meaning_id\r": "d2e34ae6-8a72-455e-b546-fafcb9c7d6cf\r"}]]
["id_unspecified_0040", [{"idiom_id": "id_unspecified_0040", "sense_number": 1, "register": ["literal"], "region": ["Indonesia"], "definitions": ["Literally, having a cutting edge that is sharp on the lower side and blunt on the upper side."], "version": 1, "created_at": "2025-11-15 05:25:26.394938", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tajam ke bawah, tumpul ke atas", "meaning_id\r": "0dbc52b5-d00a-4883-b200-8011e517f6fa\r"}, {"idiom_id": "id_unspecified_0040", "sense_number": 2, "register": ["idiomatic", "proverbial", "critical"], "region": ["Indonesia"], "definitions": ["A description of double standards in which rules or laws are applied harshly to the less powerful and leniently to the powerful; one law for the poor and another for the rich."], "version": 1, "created_at": "2025-11-15 05:25:26.394945", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tajam ke bawah, tumpul ke atas", "meaning_id\r": "7d216a13-0402-436b-8d6a-6b84bcdcf364\r"}]]
["id_unspecified_0041", [{"idiom_id": "id_unspecified_0041", "sense_number": 1, "register": ["neutral", "common"], "region": ["Indonesia", "Malaysia"], "definitions": ["To sleep; to rest in a state of reduced consciousness and diminished responsiveness to external stimuli."], "version": 1, "created_at": "2025-11-15 05:25:26.394952", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tidur", "meaning_id\r": "8e8cf7c4-736a-4894-a9ce-0bcbac6eaae8\r"}, {"idiom_id": "id_unspecified_0041", "sense_number": 2, "register": ["euphemistic", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["A euphemism for having sexual intercourse."], "version": 1, "created_at": "2025-11-15 05:25:26.394958", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tidur", "meaning_id\r": "a9c69936-bacc-4949-b299-7d56e68b2531\r"}, {"idiom_id": "id_unspecified_0041", "sense_number": 3, "register": ["figurative", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To be inactive, dormant, or not functioning (often used figuratively of objects, systems, or organizations)."], "version": 1, "created_at": "2025-11-15 05:25:26.394964", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tidur", "meaning_id\r": "6416f7a1-1a13-4890-9d03-7117c3ad7cc9\r"}]]
["id_unspecified_0042", [{"idiom_id": "id_unspecified_0042", "sense_number": 1, "register": ["literal"], "region": ["Indonesia"], "definitions": ["Literally, hot or molten lead (metal heated until liquid)."], "version": 1, "created_at": "2025-11-15 05:25:26.394972", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "timah panas", "meaning_id\r": "602a0d87-1889-4e0d-b015-424caf43a5dd\r"}, {"idiom_id": "id_unspecified_0042", "sense_number": 2, "register": ["idiomatic", "colloquial"], "region": ["Indonesia"], "definitions": ["Colloquial term for bullets or ammunition; projectiles fired from a firearm."], "version": 1, "created_at": "2025-11-15 05:25:26.39498", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "timah panas", "meaning_id\r": "a8d00109-f41f-4812-85d2-4b92d0fb7377\r"}]]
["id_unspecified_0043", [{"idiom_id": "id_unspecified_0043", "sense_number": 1, "register": ["literal", "proverbial"], "region": ["Indonesia", "Malaysia"], "definitions": ["Literally, an empty barrel makes a loud noise."], "version": 1, "created_at": "2025-11-15 05:25:26.394988", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tong kosong nyaring bunyinya", "meaning_id\r": "e3b6d78f-eb7e-45f8-a752-fb0fcb76178c\r"}, {"idiom_id": "id_unspecified_0043", "sense_number": 2, "register": ["idiomatic", "proverbial"], "region": ["Indonesia", "Malaysia"], "definitions": ["People who lack substance, knowledge, or ability often make the most noise or boast the most; empty vessels make the most sound."], "version": 1, "created_at": "2025-11-15 05:25:26.394995", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tong kosong nyaring bunyinya", "meaning_id\r": "3b33897b-5951-40d6-a90f-3c3c753db7d1\r"}]]
["id_unspecified_0044", [{"idiom_id": "id_unspecified_0044", "sense_number": 1, "register": ["neutral", "literal"], "region": ["Indonesia", "Malaysia"], "definitions": ["To close a physical book by shutting its covers."], "version": 1, "created_at": "2025-11-15 05:25:26.395007", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tutup buku", "meaning_id\r": "8848befc-32e7-4cb2-a699-bbc41797f2b9\r"}, {"idiom_id": "id_unspecified_0044", "sense_number": 2, "register": ["business", "accounting", "idiomatic"], "region": ["Indonesia"], "definitions": ["To close the books; to cease recording transactions and finalize accounting records, typically at the end of a period."], "version": 1, "created_at": "2025-11-15 05:25:26.395015", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tutup buku", "meaning_id\r": "6e1177fd-e78d-41b5-9cef-9e328966b6ca\r"}, {"idiom_id": "id_unspecified_0044", "sense_number": 3, "register": ["idiomatic", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To bring an issue to an end or to consider a matter concluded; to stop further discussion, investigation, or action on a topic."], "version": 1, "created_at": "2025-11-15 05:25:26.395021", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tutup buku", "meaning_id\r": "1a382b16-dc4e-45dd-a67c-c712b5de3107\r"}]]
["id_unspecified_0045", [{"idiom_id": "id_unspecified_0045", "sense_number": 1, "register": ["neutral", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To cover or close something physically, often intensively or repeatedly."], "version": 1, "created_at": "2025-11-15 05:25:26.395029", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tutup-tutupi", "meaning_id\r": "587b5e80-aaa2-4115-b233-e6b918d0104b\r"}, {"idiom_id": "id_unspecified_0045", "sense_number": 2, "register": ["informal", "colloquial"], "region": ["Indonesia", "Malaysia"], "definitions": ["To conceal, hide, or disguise information, facts, or wrongdoing; to cover up."], "version": 1, "created_at": "2025-11-15 05:25:26.395036", "updated_at": "2025-11-15 05:25:26.494881", "idiom": "tutup-tutupi", "meaning_id\r": "d3217de9-cb10-4a45-a3b0-0f4603ea7641\r"}]]
